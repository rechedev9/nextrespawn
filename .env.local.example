# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables
# Copy this file to .env.local and fill in every value before running the app.
# Missing required values will cause the app to exit with a clear error.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of the app (used for auth callbacks, OG images, sitemap)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase connection string (Prisma needs the pooled URL for the ORM)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true

# Direct URL used by Prisma migrations (not pooled)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Auth.js / next-auth ───────────────────────────────────────────────────────
# Secret used to sign/encrypt JWTs and session cookies (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth credentials — create at https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Email / Resend ────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_

# "From" address for all outgoing emails (must be verified in Resend)
RESEND_FROM=noreply@yourdomain.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key — starts with sk_test_ in test mode, sk_live_ in production
STRIPE_SECRET_KEY=sk_test_

# Webhook secret — from `stripe listen` output or Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_

# Price IDs from your Stripe dashboard
STRIPE_PRICE_STARTER=price_
STRIPE_PRICE_PRO=price_

# ── Lemon Squeezy (optional) ──────────────────────────────────────────────────
# Only required if PAYMENT_PROVIDER=lemonsqueezy in config.ts
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
